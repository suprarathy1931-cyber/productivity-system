# Copy this file to .env.local and fill in real values.
# .env.local is gitignored by Vite's default template — never commit
# real values, especially VITE_API_KEY.

# Base URL of the deployed Worker API (no trailing slash).
# Local dev default matches `wrangler dev --local --port 8787`.
VITE_API_BASE_URL=http://localhost:8787

# Must match the API_KEY secret set on the Worker via
# `wrangler secret put API_KEY`. This is a shared single-user secret,
# not a per-user credential — see worker/src/lib/auth.ts for context.
VITE_API_KEY=local-dev-test-key-12345
